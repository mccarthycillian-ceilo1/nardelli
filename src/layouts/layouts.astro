---
const { title = "Nardelli" } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>{title}</title>
		<style>
:root {
	--max: 900px;

	/* Warm villa palette */
	--bg: #fbfaf7;
	--card: #ffffff;
	--text: #1f2937;
	--muted: #6b7280;
	--border: #e7e5e4;
	--accent: #2f6f5e;
	--accentHover: #255a4c;
	--highlight: #d97706;

	--radius: 12px;
}

body {
	margin: 0;
	font-family: system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
	line-height: 1.5;
	background: var(--bg);
	color: var(--text);
}

header {
	border-bottom: 1px solid var(--border);
	background: var(--card);
	position: sticky;
	top: 0;
	z-index: 10;
	box-shadow: 0 1px 0 rgba(31, 41, 55, 0.06);
}

/* Thin green accent strip under the header */
header::after {
	content: "";
	display: block;
	height: 3px;
	background: var(--accent);
	opacity: 0.9;
}

.wrap {
	max-width: var(--max);
	margin: 0 auto;
	padding: 12px 16px;
}

.topbar {
	display: flex;
	align-items: center;
	justify-content: space-between;
	gap: 12px;
}

.brand {
	font-weight: 800;
	letter-spacing: 0.3px;
	color: var(--accentHover);
	text-decoration: none;
}
.brand:hover {
	color: var(--accent);
}

main {
	max-width: var(--max);
	margin: 18px auto 0;
	padding: 20px 16px 48px;
}
main > :first-child {
	background: var(--card);
	border: 1px solid var(--border);
	border-radius: var(--radius);
	padding: 18px;
}

h1 {
	margin-top: 0;
	font-size: 32px;
	line-height: 1.15;
	letter-spacing: -0.02em;
}

h1::after {
	content: "";
	display: block;
	width: 64px;
	height: 4px;
	margin-top: 10px;
	border-radius: 999px;
	background: var(--accent);
	opacity: 0.9;
}

h2 {
	margin-top: 28px;
	color: var(--accentHover);
	letter-spacing: -0.01em;
}

a {
	color: var(--accent);
}
nav a:hover {
	background: rgba(47, 111, 94, 0.12);
}

nav a {
	text-decoration: none;
	color: var(--text);
	padding: 6px 10px;
	border-radius: 10px;
}

nav a:hover {
	background: rgba(47, 111, 94, 0.12);
	color: var(--accentHover);
}

/* Desktop nav */
.nav-desktop {
	display: none;
	gap: 10px;
	align-items: center;
	flex-wrap: nowrap;
	white-space: nowrap;
}

/* Mobile menu button */
.menu-btn {
	display: inline-flex;
	align-items: center;
	gap: 8px;
	background: var(--card);
	border: 1px solid var(--border);
	border-radius: 10px;
	padding: 8px 10px;
	font-size: 14px;
	color: var(--text);
}
.menu-btn:hover {
	border-color: color-mix(in srgb, var(--accent) 35%, var(--border));
}

/* Mobile dropdown */
.nav-mobile {
	display: none;
	padding-top: 10px;
}
.nav-mobile.open {
	display: block;
}
.nav-mobile a {
	display: block;
	padding: 10px 10px;
	border-radius: 10px;
}
/* Breakpoint: show desktop nav on wider screens */
@media (min-width: 860px) {
	.menu-btn { display: none; }
	.nav-desktop { display: inline-flex; }
	.nav-mobile { display: none !important; }
}

/* Shared map sizing (narrow card on desktop, consistent across pages) */
.mapWrap {
	max-width: 680px;
	margin: 0 auto;
}

.mapFrame {
	width: 100%;
	height: 680px;
	min-height: 680px;
	border: 1px solid var(--border);
	border-radius: var(--radius);
	overflow: hidden;
	background: var(--card);
	display: block;
	line-height: 0;
}

.mapFrame iframe {
	width: 100%;
	height: 100%;
	border: 0;
	display: block;
}
</style>
	</head>
	<body>
		<header>
	<div class="wrap">
		<div class="topbar">
			<a class="brand" href="/">Nardelli</a>

			<nav class="nav-desktop" aria-label="Primary">
				<a href="/quick-start">Quick Start</a>
				<a href="/house">Our House &amp; Neighbours</a>
				<a href="/essentials">Castiglione del Lago: Essentials &amp; Sights</a>
				<a href="/restaurants">Nearby Restaurants</a>
				<a href="/day-trips">Day Trips</a>
				<a href="/leaving-checklist">Leaving Checklist</a>
			</nav>

			<button class="menu-btn" type="button" aria-expanded="false" aria-controls="mobile-nav">
				Menu
			</button>
		</div>

		<nav id="mobile-nav" class="nav-mobile" aria-label="Mobile">
			<a href="/quick-start">Quick Start</a>
			<a href="/house">Our House &amp; Neighbours</a>
			<a href="/essentials">Castiglione del Lago: Essentials &amp; Sights</a>
			<a href="/restaurants">Nearby Restaurants</a>
			<a href="/day-trips">Day Trips</a>
			<a href="/leaving-checklist">Leaving Checklist</a>
		</nav>
	</div>

	<script is:inline>
	const btn = document.querySelector(".menu-btn");
	const nav = document.querySelector("#mobile-nav");

	function setOpen(open) {
		if (!btn || !nav) return;
		nav.classList.toggle("open", open);
		btn.setAttribute("aria-expanded", String(open));
	}

	if (btn && nav) {
		btn.addEventListener("click", () => {
			const isOpen = nav.classList.contains("open");
			setOpen(!isOpen);
		});

		nav.querySelectorAll("a").forEach((a) => {
			a.addEventListener("click", () => setOpen(false));
		});
	}
</script>
		</header>

		<main>
			<slot />
		</main>
	</body>
</html>