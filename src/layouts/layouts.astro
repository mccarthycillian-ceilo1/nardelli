---
const { title = "Nardelli" } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>{title}</title>
		<style>
			:root { --max: 900px; }
			body { margin: 0; font-family: system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif; line-height: 1.5; }
			header { border-bottom: 1px solid #eee; background: #fff; position: sticky; top: 0; }
			.wrap { max-width: var(--max); margin: 0 auto; padding: 16px; }
			nav { display: flex; gap: 14px; flex-wrap: wrap; font-size: 14px; }
			nav a { text-decoration: none; color: #111; padding: 6px 8px; border-radius: 8px; }
			nav a:hover { background: #f3f3f3; }
			main { max-width: var(--max); margin: 0 auto; padding: 20px 16px 48px; }
			h1 { margin-top: 0; }
		</style>
	</head>
	<body>
		<header>
			<div class="wrap">
				<div style="display:flex; align-items:baseline; justify-content:space-between; gap:12px;">
					<strong>Nardelli</strong>
					<nav>
						<a href="/quick-start">Quick Start</a>
						<a href="/house">Our House &amp; Neighbours</a>
						<a href="/essentials">Castiglione del Lago: Essentials &amp; Sights</a>
						<a href="/restaurants">Castiglione del Lago: Restaurants</a>
						<a href="/day-trips">Day Trips</a>
						<a href="/leaving-checklist">Leaving Checklist</a>
					</nav>
				</div>
			</div>
		</header>

		<main>
			<slot />
		</main>
	</body>
</html>