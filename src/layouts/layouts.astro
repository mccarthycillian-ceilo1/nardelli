---
const { title = "Nardelli", currentPath = "" } = Astro.props;

const norm = (p: string) => (p.endsWith("/") && p !== "/" ? p.slice(0, -1) : p);
const isActive = (href: string) => norm(currentPath) === norm(href);
---


<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>{title}</title>
		<style>
:root {
	--max: 960px;

--navBg: var(--accentHover);
--navText: #fbfaf7;
--navHover: rgba(251, 250, 247, 0.14);
--navBorder: rgba(251, 250, 247, 0.22);

	/* Warm villa palette */
	--bg: #fbfaf7;
	--card: #ffffff;
	--text: #1f2937;
	--muted: #6b7280;
	--border: #e7e5e4;
	--accent: #2f6f5e;
	--accentHover: #255a4c;
	--highlight: #d97706;

	--radius: 12px;
}

body {
	margin: 0;
	font-family: system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
	line-height: 1.5;
	background: var(--bg);
	color: var(--text);
}

header {
	border-bottom: 1px solid var(--navBorder);
	background: var(--navBg);
	position: sticky;
	top: 0;
	z-index: 10;
	box-shadow: 0 1px 0 rgba(31, 41, 55, 0.10);
}

/* remove the old thin strip */
header::after {
	content: none;
}

.wrap {
	max-width: var(--max);
	margin: 0 auto;
	padding: 14px 12px;
}

.topbar {
	display: flex;
	align-items: center;
	justify-content: space-between;
	gap: 12px;
}

.brand {
	font-weight: 900;
	letter-spacing: 0.6px;
	font-size: 19px;           /* makes it stand out */
	color: var(--navText);
	text-decoration: none;
	padding: 6px 10px;
	border-radius: 10px;
}

.brand:hover {
	background: var(--navHover);
}

main {
	margin: 18px 0 0;
	padding: 0 0 48px;
}

/* Main content container (this is the key) */
main.mainWrap {
	max-width: var(--max);
	margin: 18px auto 0;
	padding: 16px 12px 48px;
	box-sizing: border-box;
}

/* Each page root becomes the “card” */
main.mainWrap > * {
	background: var(--card);
	border: 1px solid var(--border);
	border-radius: var(--radius);
	padding: 18px;
}

h1 {
	margin-top: 0;
	font-size: 32px;
	line-height: 1.15;
	letter-spacing: -0.02em;
}

h1::after {
	content: "";
	display: block;
	width: 64px;
	height: 4px;
	margin-top: 10px;
	border-radius: 999px;
	background: var(--accent);
	opacity: 0.9;
}

h2 {
	margin-top: 28px;
	color: var(--accentHover);
	letter-spacing: -0.01em;
}

a {
	color: var(--accent);
}
nav a {
	text-decoration: none;
	color: var(--navText);
	padding: 6px 8px;
	border-radius: 10px;
}

nav a:hover {
	background: var(--navHover);
	color: var(--navText);
}

/* Desktop nav */
.nav-desktop {
	display: none;
	gap: 6px;
	align-items: center;
	flex-wrap: nowrap;
	white-space: nowrap;
}

/* Mobile menu button */
.menu-btn {
	display: inline-flex;
	align-items: center;
	gap: 8px;
	background: transparent;
	border: 1px solid var(--navBorder);
	border-radius: 10px;
	padding: 8px 10px;
	font-size: 14px;
	color: var(--navText);
}

.menu-btn:hover {
	background: var(--navHover);
	border-color: rgba(251, 250, 247, 0.45);
}

/* Mobile dropdown */
.nav-mobile {
	display: none;
	padding-top: 10px;
}
.nav-mobile.open {
	display: block;
}
.nav-mobile a {
	display: block;
	padding: 10px 10px;
	border-radius: 10px;
}
/* Breakpoint: show desktop nav on wider screens */
@media (min-width: 860px) {
	.menu-btn { display: none; }
	.nav-desktop { display: inline-flex; }
	.nav-mobile { display: none !important; }
}

/* Shared map sizing (narrow card on desktop, consistent across pages) */
.mapWrap {
	max-width: 680px;
	margin: 0 auto;
}

.mapFrame {
	width: 100%;
	height: 680px;
	min-height: 680px;
	border: 1px solid var(--border);
	border-radius: var(--radius);
	overflow: hidden;
	background: var(--card);
	display: block;
	line-height: 0;
}

.mapFrame iframe {
	width: 100%;
	height: 100%;
	border: 0;
	display: block;
}

html, body {
	max-width: 100%;
	overflow-x: hidden;
}

html {
	scroll-behavior: smooth;
}

.topbar {
	min-width: 0;
}

.nav-desktop {
	min-width: 0;
}

nav a.active {
	background: rgba(251, 250, 247, 0.22);
	color: var(--navText);
	border: 1px solid rgba(251, 250, 247, 0.28);
}

.backToTop {
	position: fixed;
	right: 14px;
	bottom: 14px;
	z-index: 20;
	padding: 10px 12px;
	border-radius: 999px;
	background: var(--accentHover);
	color: var(--navText);
	text-decoration: none;
	font-weight: 800;
	font-size: 14px;
	box-shadow: 0 4px 12px rgba(31, 41, 55, 0.18);
	border: 1px solid var(--navBorder);
}

.backToTop:hover {
	background: var(--accent);
	color: var(--navText);
}

/* Show only on mobile/tablet */
@media (max-width: 859px) {
	.backToTop {
		display: inline-flex;
		align-items: center;
		justify-content: center;
	}
}

</style>
	</head>
	<body id="top">
		<header>
	<div class="wrap">
		<div class="topbar">
			<a class="brand" href="/">Nardelli</a>

			<nav class="nav-desktop" aria-label="Primary">
				<a href="/quick-start" class={isActive("/quick-start") ? "active" : ""}>Quick Start</a>
				<a href="/house" class={isActive("/house") ? "active" : ""}>Our House</a>
				<a href="/essentials" class={isActive("/essentials") ? "active" : ""}>Castiglione del Lago</a>
				<a href="/restaurants" class={isActive("/restaurants") ? "active" : ""}>Restaurants</a>
				<a href="/day-trips" class={isActive("/day-trips") ? "active" : ""}>Day Trips</a>
				<a href="/water" class={isActive("/water") ? "active" : ""}>Pools &amp; Water</a>
				<a href="/leaving-checklist" class={isActive("/leaving-checklist") ? "active" : ""}>Leaving</a>
			</nav>

			<button class="menu-btn" type="button" aria-expanded="false" aria-controls="mobile-nav">
				Menu
			</button>
		</div>

		<nav id="mobile-nav" class="nav-mobile" aria-label="Mobile">
			<a href="/quick-start" class={isActive("/quick-start") ? "active" : ""}>Quick Start</a>
				<a href="/house" class={isActive("/house") ? "active" : ""}>Our House</a>
				<a href="/essentials" class={isActive("/essentials") ? "active" : ""}>Castiglione del Lago</a>
				<a href="/restaurants" class={isActive("/restaurants") ? "active" : ""}>Restaurants</a>
				<a href="/day-trips" class={isActive("/day-trips") ? "active" : ""}>Day Trips</a>
				<a href="/water" class={isActive("/water") ? "active" : ""}>Pools &amp; Water</a>
				<a href="/leaving-checklist" class={isActive("/leaving-checklist") ? "active" : ""}>Leaving</a>
			</nav>
	</div>

	<script is:inline>
	const btn = document.querySelector(".menu-btn");
	const nav = document.querySelector("#mobile-nav");

	function setOpen(open) {
		if (!btn || !nav) return;
		nav.classList.toggle("open", open);
		btn.setAttribute("aria-expanded", String(open));
	}

	if (btn && nav) {
		btn.addEventListener("click", () => {
			const isOpen = nav.classList.contains("open");
			setOpen(!isOpen);
		});

		nav.querySelectorAll("a").forEach((a) => {
			a.addEventListener("click", () => setOpen(false));
		});
	}
</script>
		</header>
<main class="mainWrap">
	<slot />
</main>

<a href="#top" class="backToTop" aria-label="Back to top">↑ Top</a>

	</body>
</html>