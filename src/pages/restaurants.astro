---
import Layout from "../layouts/layouts.astro";
---

<Layout title="Restaurants | Nardelli">
	<h1>Castiglione del Lago: Restaurants</h1>
	<p>Curated restaurants, bars, and cafés.</p>

	<h2>Map</h2>
	<div style="width: 100%; height: 70vh; min-height: 520px; border: 1px solid #eee; border-radius: 12px; overflow: hidden;">
		<iframe
			title="Local Restaurants, Bars & Cafes"
			src="https://www.google.com/maps/d/embed?mid=1s7yXs9jQ8JVRJrBzack_63GSfhvhT-E&ehbc=2E312F"
			width="100%"
			height="100%"
			style="border:0;"
			loading="lazy"
			referrerpolicy="no-referrer-when-downgrade"
		></iframe>
	</div>
</Layout>