	<h2>Map</h2>
	<div style="width: 100%; height: 70vh; min-height: 520px; border: 1px solid #eee; border-radius: 12px; overflow: hidden;">
		<iframe
			title="Castiglione del Lago – Essentials & Sights"
			src="https://www.google.com/maps/d/embed?mid=1zJ13jcduxwEwwZeyF72jELiMLM3u15M&ehbc=2E312F"
			width="100%"
			height="100%"
			style="border:0;"
			loading="lazy"
			referrerpolicy="no-referrer-when-downgrade"
		></iframe>
	</div>
</Layout>